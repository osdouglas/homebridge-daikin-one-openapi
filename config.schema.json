{
  "pluginAlias": "DaikinOneOpenAPI",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Daikin One"
      },
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "required": true
      },
      "integratorEmail": {
        "title": "Integrator Email",
        "type": "string",
        "required": true
      },
      "integratorToken": {
        "title": "Integrator Token",
        "type": "string",
        "required": true
      },
      "pollIntervalSeconds": {
        "title": "Poll Interval Seconds",
        "type": "integer",
        "default": 180,
        "minimum": 180
      },
      "requestTimeoutSeconds": {
        "title": "Request Timeout Seconds",
        "type": "integer",
        "default": 20,
        "minimum": 1
      },
      "includeDeviceName": {
        "title": "Include Device Name",
        "type": "boolean",
        "default": true
      },
      "deviceIds": {
        "title": "Device IDs",
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "readonly": {
        "title": "Read Only",
        "type": "boolean",
        "default": false
      },
      "debug": {
        "title": "Debug Logging",
        "type": "boolean",
        "default": false
      },
      "logRaw": {
        "title": "Log Raw API Payloads",
        "type": "boolean",
        "default": false
      }
    }
  },
  "form": [
    "name",
    "apiKey",
    "integratorEmail",
    "integratorToken",
    "pollIntervalSeconds",
    "requestTimeoutSeconds",
    "includeDeviceName",
    "deviceIds",
    "readonly",
    "debug",
    "logRaw"
  ]
}
